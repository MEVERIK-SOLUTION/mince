# Zkopírujte tento soubor jako .env a doplňte vlastní hodnoty.
# NIKDY necommitujte soubor .env do gitu!
# ───────────────────────────────────────────────────────────────

# Supabase Project URL
# Najdete v: Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon (Public) Key
# Najdete v: Settings → API → Project API Keys → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

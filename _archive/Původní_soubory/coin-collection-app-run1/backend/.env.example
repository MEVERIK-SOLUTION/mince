# Příklad konfiguračního souboru
# Zkopírujte jako .env a upravte hodnoty podle potřeby

# Aplikace
APP_NAME="Coin Collection API"
VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# Databáze
DATABASE_URL=postgresql://coin_user:secure_password@localhost:5432/coin_collection
# Pro SQLite (development): DATABASE_URL=sqlite:///./coin_collection.db

# Redis cache
REDIS_URL=redis://localhost:6379

# Nahrávání souborů
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB v bytech

# Externí API klíče (volitelné)
NUMISTA_API_KEY=your_numista_api_key_here
COINSCAN_API_KEY=your_coinscan_api_key_here

# Bezpečnost
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080"]